---
import { getCollection } from 'astro:content';
import { getLang, t, getCollectionName, getArticlePath } from '@/utils/i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  currentSlug: string;
  category: string;
  tags?: string[];
}

const { currentSlug, category, tags = [] } = Astro.props;
const lang = getLang(Astro.url);
const collectionName = getCollectionName(lang);
const allPosts = await getCollection(collectionName);

// Score articles by relevance: same category + shared tags
const related = allPosts
  .filter((p) => p.slug !== currentSlug)
  .map((p) => {
    let score = 0;
    if (p.data.category === category) score += 3;
    const sharedTags = p.data.tags.filter((t: string) => tags.includes(t));
    score += sharedTags.length;
    return { post: p, score };
  })
  .filter((r) => r.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map((r) => r.post);

const sectionTitle = lang === 'fr' ? 'Articles similaires' : 'Related articles';
---

{related.length > 0 && (
  <aside class="related-articles">
    <h2 class="related-title">{sectionTitle}</h2>
    <div class="related-grid">
      {related.map((post) => (
        <a href={getArticlePath(post.slug, lang)} class="related-card">
          <span class="related-category">{post.data.category}</span>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
        </a>
      ))}
    </div>
  </aside>
)}

<style>
  .related-articles {
    max-width: var(--max-width-content);
    margin-top: var(--spacing-3xl);
    padding-top: var(--spacing-2xl);
    border-top: 2px solid var(--color-gray-200);
  }

  .related-title {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-gray-900);
    margin-bottom: var(--spacing-lg);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--spacing-md);
  }

  .related-card {
    display: block;
    padding: var(--spacing-lg);
    background: var(--color-gray-50);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .related-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .related-category {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    margin-bottom: var(--spacing-sm);
  }

  .related-card h3 {
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--color-gray-900);
    line-height: 1.4;
    margin-bottom: var(--spacing-xs);
  }

  .related-card p {
    font-size: var(--font-size-sm);
    color: var(--color-gray-500);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
