---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config/site';
import { t, getBlogPath, getCategorySlug, getCategoryPath } from '@/utils/i18n';

const lang = 'en';
const allPosts = await getCollection('blog-en');
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const title = `${siteConfig.brand.siteName} — ${siteConfig.brand.tagline.en}`;
const description = 'Independent comparisons and verified rankings. Find the best choice for your needs in tech, fashion, travel and more.';

const categoryIcons: Record<string, string> = {
  'SaaS & Logiciels': '💻',
  'Hébergement & Cloud': '☁️',
  'VPN & Sécurité': '🔒',
  'Mode': '👟',
  'Smartphones': '📱',
  'Voyage': '✈️',
  'Événements': '🎯',
  'Services': '🛠️',
};
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-container">
      <span class="hero-badge">{t(lang, 'home.trust.independent')}</span>
      <h1 class="hero-title">
        {t(lang, 'home.hero.title')}
      </h1>
      <p class="hero-subtitle">
        {t(lang, 'home.hero.subtitle')}
      </p>
      <div class="hero-ctas">
        <a href={getBlogPath(lang)} class="btn btn-primary btn-lg">
          {t(lang, 'home.viewAll')}
        </a>
        <a href="#categories" class="btn btn-outline btn-lg">
          {t(lang, 'home.categories.title')}
        </a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number">{allPosts.length}+</span>
          <span class="stat-label">Comparisons</span>
        </div>
        <div class="stat">
          <span class="stat-number">{siteConfig.categories.length}</span>
          <span class="stat-label">Categories</span>
        </div>
        <div class="stat">
          <span class="stat-number">100%</span>
          <span class="stat-label">Independent</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust / E-E-A-T -->
  <section class="section trust-section">
    <div class="container">
      <h2 class="section-title">{t(lang, 'home.trust.title')}</h2>
      <div class="trust-grid">
        <div class="trust-card">
          <div class="trust-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>{t(lang, 'home.trust.independent')}</h3>
          <p>{t(lang, 'home.trust.independentDesc')}</p>
        </div>
        <div class="trust-card">
          <div class="trust-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <h3>{t(lang, 'home.trust.methodology')}</h3>
          <p>{t(lang, 'home.trust.methodologyDesc')}</p>
        </div>
        <div class="trust-card">
          <div class="trust-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
              <polyline points="17 6 23 6 23 12"/>
            </svg>
          </div>
          <h3>{t(lang, 'home.trust.updated')}</h3>
          <p>{t(lang, 'home.trust.updatedDesc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest articles -->
  {latestPosts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>{t(lang, 'home.latest')}</h2>
          <a href={getBlogPath(lang)} class="see-all">{t(lang, 'home.viewAll')} &rarr;</a>
        </div>
        <div class="articles-grid">
          {latestPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.slug}
              category={post.data.category}
              tags={post.data.tags}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Categories -->
  <section class="section categories-section" id="categories">
    <div class="container">
      <h2 class="section-title">{t(lang, 'home.categories.title')}</h2>
      <div class="categories-grid">
        {siteConfig.categories.map((cat) => (
          <a href={getCategoryPath(getCategorySlug(cat), lang)} class="category-card">
            <span class="category-icon">{categoryIcons[cat] || '📂'}</span>
            <h3>{cat}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(160deg, var(--color-gray-50) 0%, rgba(5, 150, 105, 0.08) 50%, rgba(16, 185, 129, 0.04) 100%);
    padding: var(--spacing-4xl) 0;
    text-align: center;
  }

  .hero-container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    background: rgba(5, 150, 105, 0.1);
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: var(--radius-full);
    margin-bottom: var(--spacing-lg);
  }

  .hero-title {
    font-size: var(--font-size-5xl);
    font-weight: 800;
    color: var(--color-gray-900);
    line-height: 1.1;
    margin-bottom: var(--spacing-lg);
    max-width: 700px;
  }

  .hero-subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-gray-500);
    max-width: 560px;
    margin-bottom: var(--spacing-xl);
    line-height: 1.6;
  }

  .hero-ctas {
    display: flex;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-3xl);
  }

  .btn-lg {
    padding: var(--spacing-md) var(--spacing-xl);
    font-size: var(--font-size-base);
  }

  .hero-stats {
    display: flex;
    gap: var(--spacing-3xl);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-number {
    font-size: var(--font-size-3xl);
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: var(--font-size-sm);
    color: var(--color-gray-400);
    margin-top: var(--spacing-xs);
  }

  .trust-section {
    background: var(--color-white);
  }

  .section-title {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--color-gray-900);
    margin-bottom: var(--spacing-xl);
    text-align: center;
  }

  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-xl);
  }

  .trust-card {
    text-align: center;
    padding: var(--spacing-xl);
  }

  .trust-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-xl);
    background: rgba(5, 150, 105, 0.08);
    margin-bottom: var(--spacing-md);
  }

  .trust-card h3 {
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--color-gray-900);
    margin-bottom: var(--spacing-sm);
  }

  .trust-card p {
    font-size: var(--font-size-sm);
    color: var(--color-gray-500);
    line-height: 1.6;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-xl);
  }

  .section-header h2 {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--color-gray-900);
  }

  .see-all {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .see-all:hover {
    text-decoration: underline;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--spacing-xl);
  }

  .categories-section {
    background-color: var(--color-gray-50);
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--spacing-lg);
  }

  .category-card {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg) var(--spacing-xl);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .category-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .category-icon {
    font-size: var(--font-size-2xl);
    line-height: 1;
  }

  .category-card h3 {
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--color-gray-800);
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--spacing-2xl) 0;
    }

    .hero-title {
      font-size: var(--font-size-3xl);
    }

    .hero-ctas {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
    }

    .hero-stats {
      gap: var(--spacing-xl);
    }

    .stat-number {
      font-size: var(--font-size-2xl);
    }

    .trust-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }

    .articles-grid {
      grid-template-columns: 1fr;
    }

    .categories-grid {
      grid-template-columns: 1fr;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--spacing-sm);
    }
  }
</style>
